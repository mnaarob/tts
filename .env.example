# Supabase - get your publishable key from https://supabase.com/dashboard/project/iyubmgzxypcanrbyuyck/settings/api
# Use the publishable key only - never put the secret key in frontend code
VITE_SUPABASE_URL=https://iyubmgzxypcanrbyuyck.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Cloudflare Turnstile site key (public). Required when Supabase Auth has CAPTCHA enabled.
# Create a widget at https://dash.cloudflare.com/ → Turnstile; allow localhost for local dev.
# The secret key belongs only in Supabase Dashboard → Authentication → Bot and Abuse Protection.
VITE_TURNSTILE_SITE_KEY=
