# Copy to `.env.local` for local development (never commit `.env.local`).
# Supabase — publishable (anon) key only; never put the service role / secret key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Cloudflare Turnstile site key (public). Required when Supabase Auth has CAPTCHA enabled.
# Create a widget at https://dash.cloudflare.com/ → Turnstile; allow localhost for local dev.
# The Turnstile *secret* key belongs only in:
#   - Supabase Dashboard → Authentication → Bot and Abuse Protection
#   - Supabase Edge Function secret: TURNSTILE_SECRET_KEY (for employee signup)
VITE_TURNSTILE_SITE_KEY=
